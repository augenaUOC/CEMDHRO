    <owl:Class rdf:about="https://augenauoc.github.io/CEMDHRO//OpenSafetyAlert">
        <rdfs:comment>Safety alert inferred as open when its status is Open.</rdfs:comment>
        <rdfs:label>OpenSafetyAlert</rdfs:label>
    </owl:Class>
    


    <!-- https://augenauoc.github.io/CEMDHRO//PatientHarm -->


    <owl:Class rdf:about="https://augenauoc.github.io/CEMDHRO//PatientHarm">
        <rdfs:subClassOf rdf:resource="https://augenauoc.github.io/CEMDHRO//Risk"/>
        <rdfs:label>PatientHarm</rdfs:label>
    </owl:Class>
    


