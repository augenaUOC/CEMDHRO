        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Indicates whether the device is active</rdfs:comment>
        <rdfs:label>isActive</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://augenauoc.github.io/CEMDHRO//isIVD -->


    <owl:DatatypeProperty rdf:about="https://augenauoc.github.io/CEMDHRO//isIVD">
        <rdfs:domain rdf:resource="https://augenauoc.github.io/CEMDHRO//Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Indicates whether the device is an in vitro diagnostic device</rdfs:comment>
        <rdfs:label>isIVD</rdfs:label>
    </owl:DatatypeProperty>
    


