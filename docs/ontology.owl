    </owl:Class>
    


    <!-- https://augenauoc.github.io/CEMDHRO//RegulatoryFramework -->


    <owl:Class rdf:about="https://augenauoc.github.io/CEMDHRO//RegulatoryFramework">
        <rdfs:comment>European regulatory framework governing medical devices.</rdfs:comment>
        <rdfs:label>RegulatoryFramework</rdfs:label>
    </owl:Class>
    


    <!-- https://augenauoc.github.io/CEMDHRO//Risk -->


    <owl:Class rdf:about="https://augenauoc.github.io/CEMDHRO//Risk">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://augenauoc.github.io/CEMDHRO//hasSeverity"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:oneOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://augenauoc.github.io/CEMDHRO//Critical_instance"/>
                            <rdf:Description rdf:about="https://augenauoc.github.io/CEMDHRO//Moderate_instance"/>
                            <rdf:Description rdf:about="https://augenauoc.github.io/CEMDHRO//Serious_instance"/>
                        </owl:oneOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://augenauoc.github.io/CEMDHRO//hasSeverity"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://augenauoc.github.io/CEMDHRO//Critical"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Potential hazard or adverse effect associated with a medical device.</rdfs:comment>
        <rdfs:label>Risk</rdfs:label>
    </owl:Class>
    


    <!-- https://augenauoc.github.io/CEMDHRO//RiskClass -->


    <owl:Class rdf:about="https://augenauoc.github.io/CEMDHRO//RiskClass">
        <rdfs:comment>Type of risk regulated under MDR or IVDR</rdfs:comment>
        <rdfs:label>RiskClass</rdfs:label>
    </owl:Class>
    


