    <!-- https://augenauoc.github.io/CEMDHRO//Incident -->


    <owl:Class rdf:about="https://augenauoc.github.io/CEMDHRO//Incident">
        <rdfs:subClassOf rdf:resource="https://augenauoc.github.io/CEMDHRO/DescribedEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://augenauoc.github.io/CEMDHRO//affectsDevice"/>
                <owl:someValuesFrom rdf:resource="https://augenauoc.github.io/CEMDHRO//Device"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Event related to the use of a medical device that may impact patient safety.</rdfs:comment>
        <rdfs:label>Incident</rdfs:label>
    </owl:Class>
    


