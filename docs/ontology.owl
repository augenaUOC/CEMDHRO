            </rdf:Description>
        </swrl:head>
    </rdf:Description>
    <rdf:Description>
        <swrla:isRuleEnabled rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</swrla:isRuleEnabled>
        <rdfs:comment>Recall inferred as closed when its status is Closed.</rdfs:comment>
        <rdfs:label>ClosedRecallRule</rdfs:label>
