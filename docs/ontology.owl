        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Indicates whether the device is implantable</rdfs:comment>
        <rdfs:label>isImplantable</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://augenauoc.github.io/CEMDHRO//isReusable -->


    <owl:DatatypeProperty rdf:about="https://augenauoc.github.io/CEMDHRO//isReusable">
