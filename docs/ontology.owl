<?xml version="1.0"?>
<rdf:RDF xmlns="https://augenauoc.github.io/CEMDHRO/"
     xml:base="https://augenauoc.github.io/CEMDHRO/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:CEMDHRO="https://augenauoc.github.io/CEMDHRO//">
    <owl:Ontology rdf:about="https://augenauoc.github.io/CEMDHRO/">
        <owl:versionIRI rdf:resource="https://augenauoc.github.io/CEMDHRO/"/>
		<dc:creator> AlfonsoUS </dc:creator>
		<dc:title>CEMDHRO</dc:title>
        <rdfs:comment>The CEMDHRO ontology has been developed to provide a structured and semantic representation of high-risk medical devices within the European regulatory context. It integrates key elements such as devices, manufacturers, risk classifications, incidents, and corrective actions, enabling consistent data modelling and interoperability. This ontology aims to support analysis, traceability, and decision-making processes in the domain of medical device safety and regulation.</rdfs:comment>
        <rdfs:label>CEMDHRO</rdfs:label>
        <owl:versionInfo rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">2.10</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled -->


    <owl:AnnotationProperty rdf:about="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
    


    <!-- https://augenauoc.github.io/CEMDHRO//hasIMDRFCode -->


    <owl:AnnotationProperty rdf:about="https://augenauoc.github.io/CEMDHRO//hasIMDRFCode"/>
    


    <!-- https://augenauoc.github.io/CEMDHRO//hasIncidentId -->


    <owl:AnnotationProperty rdf:about="https://augenauoc.github.io/CEMDHRO//hasIncidentId"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://augenauoc.github.io/CEMDHRO/hasIMDRFCode -->


    <owl:ObjectProperty rdf:about="https://augenauoc.github.io/CEMDHRO/hasIMDRFCode">
        <owl:inverseOf rdf:resource="https://augenauoc.github.io/CEMDHRO/isIMDRFCodeOf"/>
        <rdfs:domain rdf:resource="https://augenauoc.github.io/CEMDHRO//Risk"/>
        <rdfs:range rdf:resource="https://augenauoc.github.io/CEMDHRO//IMDRFCode"/>
        <rdfs:label>hasIMDRFCode</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://augenauoc.github.io/CEMDHRO/isAddressedBy -->


    <owl:ObjectProperty rdf:about="https://augenauoc.github.io/CEMDHRO/isAddressedBy">
        <owl:inverseOf rdf:resource="https://augenauoc.github.io/CEMDHRO//addressesIncident"/>
        <rdfs:domain rdf:resource="https://augenauoc.github.io/CEMDHRO//Incident"/>
        <rdfs:range rdf:resource="https://augenauoc.github.io/CEMDHRO//CorrectiveAction"/>
        <rdfs:label>isAddressedBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://augenauoc.github.io/CEMDHRO/isAffectedDeviceTypeOf -->


    <owl:ObjectProperty rdf:about="https://augenauoc.github.io/CEMDHRO/isAffectedDeviceTypeOf">
        <owl:inverseOf rdf:resource="https://augenauoc.github.io/CEMDHRO//affectsDeviceType"/>
        <rdfs:domain rdf:resource="https://augenauoc.github.io/CEMDHRO//Device"/>
        <rdfs:range rdf:resource="https://augenauoc.github.io/CEMDHRO//Risk"/>
        <rdfs:label>isAffectedDeviceTypeOf</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://augenauoc.github.io/CEMDHRO/isAffectedRegionOf -->


    <owl:ObjectProperty rdf:about="https://augenauoc.github.io/CEMDHRO/isAffectedRegionOf">
        <owl:inverseOf rdf:resource="https://augenauoc.github.io/CEMDHRO//affectsRegion"/>
        <rdfs:domain rdf:resource="https://augenauoc.github.io/CEMDHRO//Region"/>
        <rdfs:range rdf:resource="https://augenauoc.github.io/CEMDHRO//CorrectiveAction"/>
        <rdfs:label>isAffectedRegionOf</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://augenauoc.github.io/CEMDHRO/isAffectedUnitOf -->


    <owl:ObjectProperty rdf:about="https://augenauoc.github.io/CEMDHRO/isAffectedUnitOf">
        <owl:inverseOf rdf:resource="https://augenauoc.github.io/CEMDHRO//hasAffectedUnit"/>
        <rdfs:domain rdf:resource="https://augenauoc.github.io/CEMDHRO//AffectedUnit"/>
        <rdfs:range rdf:resource="https://augenauoc.github.io/CEMDHRO//CorrectiveAction"/>
        <rdfs:label>isAffectedUnitOf</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://augenauoc.github.io/CEMDHRO/isIMDRFCodeOf -->


    <owl:ObjectProperty rdf:about="https://augenauoc.github.io/CEMDHRO/isIMDRFCodeOf">
        <rdfs:domain rdf:resource="https://augenauoc.github.io/CEMDHRO//IMDRFCode"/>
        <rdfs:range rdf:resource="https://augenauoc.github.io/CEMDHRO//Risk"/>
        <rdfs:label>isIMDRFCodeOf</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://augenauoc.github.io/CEMDHRO/isLocationOf -->


    <owl:ObjectProperty rdf:about="https://augenauoc.github.io/CEMDHRO/isLocationOf">
        <owl:inverseOf rdf:resource="https://augenauoc.github.io/CEMDHRO//locatedIn"/>
        <rdfs:domain rdf:resource="https://augenauoc.github.io/CEMDHRO//Region"/>
        <rdfs:range rdf:resource="https://augenauoc.github.io/CEMDHRO//Manufacturer"/>
        <rdfs:label>isLocationOf</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://augenauoc.github.io/CEMDHRO/isPatientSexOf -->


    <owl:ObjectProperty rdf:about="https://augenauoc.github.io/CEMDHRO/isPatientSexOf">
        <owl:inverseOf rdf:resource="https://augenauoc.github.io/CEMDHRO//hasPatientSex"/>
        <rdfs:domain rdf:resource="https://augenauoc.github.io/CEMDHRO//PatientSex"/>
        <rdfs:range rdf:resource="https://augenauoc.github.io/CEMDHRO//Incident"/>
        <rdfs:label>isPatientSexOf</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://augenauoc.github.io/CEMDHRO/isProbabilityOf -->


    <owl:ObjectProperty rdf:about="https://augenauoc.github.io/CEMDHRO/isProbabilityOf">
        <owl:inverseOf rdf:resource="https://augenauoc.github.io/CEMDHRO//hasProbability"/>
        <rdfs:domain rdf:resource="https://augenauoc.github.io/CEMDHRO//Probability"/>
        <rdfs:range rdf:resource="https://augenauoc.github.io/CEMDHRO//Risk"/>
        <rdfs:label>isProbabilityOf</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://augenauoc.github.io/CEMDHRO/isReportLocationOf -->


    <owl:ObjectProperty rdf:about="https://augenauoc.github.io/CEMDHRO/isReportLocationOf">
        <owl:inverseOf rdf:resource="https://augenauoc.github.io/CEMDHRO//reportedIn"/>
        <rdfs:domain rdf:resource="https://augenauoc.github.io/CEMDHRO//Region"/>
        <rdfs:range rdf:resource="https://augenauoc.github.io/CEMDHRO//Incident"/>
        <rdfs:label>isReportLocationOf</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://augenauoc.github.io/CEMDHRO/isRiskClassOf -->


    <owl:ObjectProperty rdf:about="https://augenauoc.github.io/CEMDHRO/isRiskClassOf">
        <owl:inverseOf rdf:resource="https://augenauoc.github.io/CEMDHRO//hasRiskClass"/>
        <rdfs:domain rdf:resource="https://augenauoc.github.io/CEMDHRO//RiskClass"/>
        <rdfs:range rdf:resource="https://augenauoc.github.io/CEMDHRO//Device"/>
        <rdfs:label>isRiskClassOf</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://augenauoc.github.io/CEMDHRO/isRiskOf -->


    <owl:ObjectProperty rdf:about="https://augenauoc.github.io/CEMDHRO/isRiskOf">
        <owl:inverseOf rdf:resource="https://augenauoc.github.io/CEMDHRO//hasRisk"/>
        <rdfs:domain rdf:resource="https://augenauoc.github.io/CEMDHRO//Risk"/>
        <rdfs:range rdf:resource="https://augenauoc.github.io/CEMDHRO//Incident"/>
        <rdfs:label>isRiskOf</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://augenauoc.github.io/CEMDHRO/isSeverityOf -->


    <owl:ObjectProperty rdf:about="https://augenauoc.github.io/CEMDHRO/isSeverityOf">
        <owl:inverseOf rdf:resource="https://augenauoc.github.io/CEMDHRO//hasSeverity"/>
        <rdfs:domain rdf:resource="https://augenauoc.github.io/CEMDHRO//Severity"/>
        <rdfs:range rdf:resource="https://augenauoc.github.io/CEMDHRO//Risk"/>
        <rdfs:label>isSeverityOf</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://augenauoc.github.io/CEMDHRO/isStatusOf -->


    <owl:ObjectProperty rdf:about="https://augenauoc.github.io/CEMDHRO/isStatusOf">
        <owl:inverseOf rdf:resource="https://augenauoc.github.io/CEMDHRO//hasStatus"/>
        <rdfs:domain rdf:resource="https://augenauoc.github.io/CEMDHRO//Status"/>
        <rdfs:range rdf:resource="https://augenauoc.github.io/CEMDHRO//CorrectiveAction"/>
        <rdfs:label>isStatusOf</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://augenauoc.github.io/CEMDHRO/regulatesDevice -->


    <owl:ObjectProperty rdf:about="https://augenauoc.github.io/CEMDHRO/regulatesDevice">
        <owl:inverseOf rdf:resource="https://augenauoc.github.io/CEMDHRO//regulatedUnder"/>
        <rdfs:domain rdf:resource="https://augenauoc.github.io/CEMDHRO//RegulatoryFramework"/>
        <rdfs:range rdf:resource="https://augenauoc.github.io/CEMDHRO//Device"/>
        <rdfs:label>regulatesDevice</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://augenauoc.github.io/CEMDHRO/reportsIncident -->


    <owl:ObjectProperty rdf:about="https://augenauoc.github.io/CEMDHRO/reportsIncident">
        <rdfs:domain rdf:resource="https://augenauoc.github.io/CEMDHRO//Manufacturer"/>
        <rdfs:range rdf:resource="https://augenauoc.github.io/CEMDHRO//Incident"/>
        <rdfs:label>reportsIncident</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://augenauoc.github.io/CEMDHRO//addressesIncident -->


    <owl:ObjectProperty rdf:about="https://augenauoc.github.io/CEMDHRO//addressesIncident">
        <rdfs:domain rdf:resource="https://augenauoc.github.io/CEMDHRO//CorrectiveAction"/>
        <rdfs:range rdf:resource="https://augenauoc.github.io/CEMDHRO//Incident"/>
        <rdfs:comment>Relates a corrective action to the incident it addresses</rdfs:comment>
        <rdfs:label>addressesIncident</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://augenauoc.github.io/CEMDHRO//affectsDevice -->


    <owl:ObjectProperty rdf:about="https://augenauoc.github.io/CEMDHRO//affectsDevice">
        <owl:inverseOf rdf:resource="https://augenauoc.github.io/CEMDHRO//isAffectedBy"/>
        <rdfs:domain rdf:resource="https://augenauoc.github.io/CEMDHRO//Incident"/>
        <rdfs:range rdf:resource="https://augenauoc.github.io/CEMDHRO//Device"/>
        <rdfs:comment>Relates an incident to the affected medical device</rdfs:comment>
        <rdfs:label>affectsDevice</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://augenauoc.github.io/CEMDHRO//affectsDeviceType -->


    <owl:ObjectProperty rdf:about="https://augenauoc.github.io/CEMDHRO//affectsDeviceType">
        <rdfs:domain rdf:resource="https://augenauoc.github.io/CEMDHRO//Risk"/>
        <rdfs:range rdf:resource="https://augenauoc.github.io/CEMDHRO//Device"/>
        <rdfs:label>affectsDeviceType</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://augenauoc.github.io/CEMDHRO//affectsRegion -->


    <owl:ObjectProperty rdf:about="https://augenauoc.github.io/CEMDHRO//affectsRegion">
        <rdfs:domain rdf:resource="https://augenauoc.github.io/CEMDHRO//CorrectiveAction"/>
        <rdfs:range rdf:resource="https://augenauoc.github.io/CEMDHRO//Region"/>
        <rdfs:comment>Relates a corrective action to the affected geographical region</rdfs:comment>
        <rdfs:label>affectsRegion</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://augenauoc.github.io/CEMDHRO//hasAffectedUnit -->


    <owl:ObjectProperty rdf:about="https://augenauoc.github.io/CEMDHRO//hasAffectedUnit">
        <rdfs:domain rdf:resource="https://augenauoc.github.io/CEMDHRO//CorrectiveAction"/>
        <rdfs:range rdf:resource="https://augenauoc.github.io/CEMDHRO//AffectedUnit"/>
        <rdfs:comment>Indicates the unit used for the affected quantity</rdfs:comment>
        <rdfs:label>hasAffectedUnit</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://augenauoc.github.io/CEMDHRO//hasManufacturer -->


    <owl:ObjectProperty rdf:about="https://augenauoc.github.io/CEMDHRO//hasManufacturer">
        <owl:inverseOf rdf:resource="https://augenauoc.github.io/CEMDHRO//manufactures"/>
        <rdfs:domain rdf:resource="https://augenauoc.github.io/CEMDHRO//Device"/>
        <rdfs:range rdf:resource="https://augenauoc.github.io/CEMDHRO//Manufacturer"/>
        <rdfs:comment>Relates a medical device to its manufacturer</rdfs:comment>
        <rdfs:label>hasManufacturer</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://augenauoc.github.io/CEMDHRO//hasPatientSex -->


    <owl:ObjectProperty rdf:about="https://augenauoc.github.io/CEMDHRO//hasPatientSex">
        <rdfs:domain rdf:resource="https://augenauoc.github.io/CEMDHRO//Incident"/>
        <rdfs:range rdf:resource="https://augenauoc.github.io/CEMDHRO//PatientSex"/>
        <rdfs:label>hasPatientSex</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://augenauoc.github.io/CEMDHRO//hasProbability -->


    <owl:ObjectProperty rdf:about="https://augenauoc.github.io/CEMDHRO//hasProbability">
        <rdfs:domain rdf:resource="https://augenauoc.github.io/CEMDHRO//Risk"/>
        <rdfs:range rdf:resource="https://augenauoc.github.io/CEMDHRO//Probability"/>
        <rdfs:comment>Relates a risk to its probability level</rdfs:comment>
        <rdfs:label>hasProbability</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://augenauoc.github.io/CEMDHRO//hasRisk -->


    <owl:ObjectProperty rdf:about="https://augenauoc.github.io/CEMDHRO//hasRisk">
        <rdfs:domain rdf:resource="https://augenauoc.github.io/CEMDHRO//Incident"/>
        <rdfs:range rdf:resource="https://augenauoc.github.io/CEMDHRO//Risk"/>
        <rdfs:comment>Relates a device or incident to an associated risk</rdfs:comment>
        <rdfs:label>hasRisk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://augenauoc.github.io/CEMDHRO//hasRiskClass -->


    <owl:ObjectProperty rdf:about="https://augenauoc.github.io/CEMDHRO//hasRiskClass">
        <rdfs:domain rdf:resource="https://augenauoc.github.io/CEMDHRO//Device"/>
        <rdfs:range rdf:resource="https://augenauoc.github.io/CEMDHRO//RiskClass"/>
        <rdfs:comment>Relates a device to its regulatory risk class</rdfs:comment>
        <rdfs:label>hasRiskClass</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://augenauoc.github.io/CEMDHRO//hasSeverity -->


    <owl:ObjectProperty rdf:about="https://augenauoc.github.io/CEMDHRO//hasSeverity">
        <rdfs:domain rdf:resource="https://augenauoc.github.io/CEMDHRO//Risk"/>
        <rdfs:range rdf:resource="https://augenauoc.github.io/CEMDHRO//Severity"/>
        <rdfs:comment>Relates a risk to its severity level</rdfs:comment>
        <rdfs:label>hasSeverity</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://augenauoc.github.io/CEMDHRO//hasStatus -->


    <owl:ObjectProperty rdf:about="https://augenauoc.github.io/CEMDHRO//hasStatus">
        <rdfs:domain rdf:resource="https://augenauoc.github.io/CEMDHRO//CorrectiveAction"/>
        <rdfs:range rdf:resource="https://augenauoc.github.io/CEMDHRO//Status"/>
        <rdfs:comment>Relates a corrective action to its current status</rdfs:comment>
        <rdfs:label>hasStatus</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://augenauoc.github.io/CEMDHRO//isAffectedBy -->


    <owl:ObjectProperty rdf:about="https://augenauoc.github.io/CEMDHRO//isAffectedBy">
        <rdfs:domain rdf:resource="https://augenauoc.github.io/CEMDHRO//Device"/>
        <rdfs:range rdf:resource="https://augenauoc.github.io/CEMDHRO//Incident"/>
        <rdfs:label>isAffectedBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://augenauoc.github.io/CEMDHRO//locatedIn -->


    <owl:ObjectProperty rdf:about="https://augenauoc.github.io/CEMDHRO//locatedIn">
        <rdfs:domain rdf:resource="https://augenauoc.github.io/CEMDHRO//Manufacturer"/>
        <rdfs:range rdf:resource="https://augenauoc.github.io/CEMDHRO//Region"/>
        <rdfs:comment>Relates a manufacturer to its geographical region</rdfs:comment>
        <rdfs:label>locatedIn</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://augenauoc.github.io/CEMDHRO//manufactures -->


    <owl:ObjectProperty rdf:about="https://augenauoc.github.io/CEMDHRO//manufactures">
        <rdfs:domain rdf:resource="https://augenauoc.github.io/CEMDHRO//Manufacturer"/>
        <rdfs:range rdf:resource="https://augenauoc.github.io/CEMDHRO//Device"/>
        <rdfs:comment>Relates a manufacturer to the devices it produces</rdfs:comment>
        <rdfs:label>manufactures</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://augenauoc.github.io/CEMDHRO//regulatedUnder -->


    <owl:ObjectProperty rdf:about="https://augenauoc.github.io/CEMDHRO//regulatedUnder">
        <rdfs:domain rdf:resource="https://augenauoc.github.io/CEMDHRO//Device"/>
        <rdfs:range rdf:resource="https://augenauoc.github.io/CEMDHRO//RegulatoryFramework"/>
        <rdfs:comment>Relates a device to the applicable regulatory framework</rdfs:comment>
        <rdfs:label>regulatedUnder</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://augenauoc.github.io/CEMDHRO//reportedBy -->


    <owl:ObjectProperty rdf:about="https://augenauoc.github.io/CEMDHRO//reportedBy">
        <rdfs:domain rdf:resource="https://augenauoc.github.io/CEMDHRO//Incident"/>
        <rdfs:range rdf:resource="https://augenauoc.github.io/CEMDHRO//Manufacturer"/>
        <rdfs:comment>Relates an incident to the manufacturer that reported it</rdfs:comment>
        <rdfs:label>reportedBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://augenauoc.github.io/CEMDHRO//reportedIn -->


    <owl:ObjectProperty rdf:about="https://augenauoc.github.io/CEMDHRO//reportedIn">
        <rdfs:domain rdf:resource="https://augenauoc.github.io/CEMDHRO//Incident"/>
        <rdfs:range rdf:resource="https://augenauoc.github.io/CEMDHRO//Region"/>
        <rdfs:comment>Relates an incident to the region where it was reported</rdfs:comment>
        <rdfs:label>reportedIn</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://augenauoc.github.io/CEMDHRO//hasActionDate -->


    <owl:DatatypeProperty rdf:about="https://augenauoc.github.io/CEMDHRO//hasActionDate">
        <rdfs:domain rdf:resource="https://augenauoc.github.io/CEMDHRO//CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>Date when the corrective action was initiated</rdfs:comment>
        <rdfs:label>hasActionDate</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://augenauoc.github.io/CEMDHRO//hasAffectedQuantity -->


    <owl:DatatypeProperty rdf:about="https://augenauoc.github.io/CEMDHRO//hasAffectedQuantity">
        <rdfs:domain rdf:resource="https://augenauoc.github.io/CEMDHRO//CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Number of affected devices or tests</rdfs:comment>
        <rdfs:label>hasAffectedQuantity</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://augenauoc.github.io/CEMDHRO//hasAuthorizationNumber -->


    <owl:DatatypeProperty rdf:about="https://augenauoc.github.io/CEMDHRO//hasAuthorizationNumber">
        <rdfs:domain rdf:resource="https://augenauoc.github.io/CEMDHRO//Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Authorization number assigned to a manufacturer</rdfs:comment>
        <rdfs:label>hasAuthorizationNumber</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://augenauoc.github.io/CEMDHRO//hasClosureDate -->


    <owl:DatatypeProperty rdf:about="https://augenauoc.github.io/CEMDHRO//hasClosureDate">
        <rdfs:domain rdf:resource="https://augenauoc.github.io/CEMDHRO//CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>Date when the corrective action was closed</rdfs:comment>
        <rdfs:label>hasClosureDate</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://augenauoc.github.io/CEMDHRO//hasCompetentAuthority -->


    <owl:DatatypeProperty rdf:about="https://augenauoc.github.io/CEMDHRO//hasCompetentAuthority">
        <rdfs:domain rdf:resource="https://augenauoc.github.io/CEMDHRO//Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Competent authority responsible for the manufacturer</rdfs:comment>
        <rdfs:label>hasCompetentAuthority</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://augenauoc.github.io/CEMDHRO//hasCorrectiveActionTaken -->


    <owl:DatatypeProperty rdf:about="https://augenauoc.github.io/CEMDHRO//hasCorrectiveActionTaken">
        <rdfs:domain rdf:resource="https://augenauoc.github.io/CEMDHRO//Incident"/>
