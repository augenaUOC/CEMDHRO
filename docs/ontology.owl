     -->


    


    <!-- https://augenauoc.github.io/CEMDHRO/DescribedEntity -->


    <owl:Class rdf:about="https://augenauoc.github.io/CEMDHRO/DescribedEntity">
        <rdfs:label>DescribedEntity</rdfs:label>
    </owl:Class>
    


    <!-- https://augenauoc.github.io/CEMDHRO//ActiveDevice -->


    <owl:Class rdf:about="https://augenauoc.github.io/CEMDHRO//ActiveDevice">
        <rdfs:subClassOf rdf:resource="https://augenauoc.github.io/CEMDHRO//Device"/>
    </owl:Class>
    


    <!-- https://augenauoc.github.io/CEMDHRO//ActiveImplant -->


    <owl:Class rdf:about="https://augenauoc.github.io/CEMDHRO//ActiveImplant">
        <rdfs:subClassOf rdf:resource="https://augenauoc.github.io/CEMDHRO//Device"/>
    </owl:Class>
    


    <!-- https://augenauoc.github.io/CEMDHRO//AffectedUnit -->


    <owl:Class rdf:about="https://augenauoc.github.io/CEMDHRO//AffectedUnit">
        <rdfs:comment>Number of affected units</rdfs:comment>
        <rdfs:label>AffectedUnit</rdfs:label>
    </owl:Class>
    


    <!-- https://augenauoc.github.io/CEMDHRO//ClassA -->


    <owl:Class rdf:about="https://augenauoc.github.io/CEMDHRO//ClassA">
        <rdfs:subClassOf rdf:resource="https://augenauoc.github.io/CEMDHRO//IVDRRiskClass"/>
        <rdfs:label>ClassA</rdfs:label>
    </owl:Class>
    


    <!-- https://augenauoc.github.io/CEMDHRO//ClassB -->


    <owl:Class rdf:about="https://augenauoc.github.io/CEMDHRO//ClassB">
        <rdfs:subClassOf rdf:resource="https://augenauoc.github.io/CEMDHRO//IVDRRiskClass"/>
        <rdfs:label>ClassB</rdfs:label>
    </owl:Class>
    


    <!-- https://augenauoc.github.io/CEMDHRO//ClassC -->


    <owl:Class rdf:about="https://augenauoc.github.io/CEMDHRO//ClassC">
        <rdfs:subClassOf rdf:resource="https://augenauoc.github.io/CEMDHRO//IVDRRiskClass"/>
        <rdfs:label>ClassC</rdfs:label>
    </owl:Class>
    


    <!-- https://augenauoc.github.io/CEMDHRO//ClassD -->


    <owl:Class rdf:about="https://augenauoc.github.io/CEMDHRO//ClassD">
        <rdfs:subClassOf rdf:resource="https://augenauoc.github.io/CEMDHRO//IVDRRiskClass"/>
        <rdfs:label>ClassD</rdfs:label>
    </owl:Class>
    


    <!-- https://augenauoc.github.io/CEMDHRO//ClassI -->


    <owl:Class rdf:about="https://augenauoc.github.io/CEMDHRO//ClassI">
        <rdfs:subClassOf rdf:resource="https://augenauoc.github.io/CEMDHRO//MDRRiskClass"/>
        <rdfs:label>ClassI</rdfs:label>
    </owl:Class>
    


    <!-- https://augenauoc.github.io/CEMDHRO//ClassIII -->


    <owl:Class rdf:about="https://augenauoc.github.io/CEMDHRO//ClassIII">
        <rdfs:subClassOf rdf:resource="https://augenauoc.github.io/CEMDHRO//MDRRiskClass"/>
        <rdfs:comment>Highest risk category.</rdfs:comment>
        <rdfs:label>ClassIII</rdfs:label>
    </owl:Class>
    


    <!-- https://augenauoc.github.io/CEMDHRO//ClassIIa -->


    <owl:Class rdf:about="https://augenauoc.github.io/CEMDHRO//ClassIIa">
        <rdfs:subClassOf rdf:resource="https://augenauoc.github.io/CEMDHRO//MDRRiskClass"/>
        <rdfs:label>ClassIIa</rdfs:label>
    </owl:Class>
    


    <!-- https://augenauoc.github.io/CEMDHRO//ClassIIb -->


    <owl:Class rdf:about="https://augenauoc.github.io/CEMDHRO//ClassIIb">
        <rdfs:subClassOf rdf:resource="https://augenauoc.github.io/CEMDHRO//MDRRiskClass"/>
        <rdfs:label>ClassIIb</rdfs:label>
    </owl:Class>
    


    <!-- https://augenauoc.github.io/CEMDHRO//Closed -->


    <owl:Class rdf:about="https://augenauoc.github.io/CEMDHRO//Closed">
        <rdfs:subClassOf rdf:resource="https://augenauoc.github.io/CEMDHRO//Status"/>
        <owl:disjointWith rdf:resource="https://augenauoc.github.io/CEMDHRO//Open"/>
        <rdfs:label>Closed</rdfs:label>
    </owl:Class>
    


    <!-- https://augenauoc.github.io/CEMDHRO//ClosedRecall -->


    <owl:Class rdf:about="https://augenauoc.github.io/CEMDHRO//ClosedRecall">
        <rdfs:comment>Recall inferred as closed when its status is Closed.</rdfs:comment>
        <rdfs:label>ClosedRecall</rdfs:label>
    </owl:Class>
    


    <!-- https://augenauoc.github.io/CEMDHRO//ContaminationRisk -->


    <owl:Class rdf:about="https://augenauoc.github.io/CEMDHRO//ContaminationRisk">
        <rdfs:subClassOf rdf:resource="https://augenauoc.github.io/CEMDHRO//ProductQuality"/>
        <rdfs:subClassOf rdf:resource="https://augenauoc.github.io/CEMDHRO//Risk"/>
        <rdfs:label>ContaminationRisk</rdfs:label>
    </owl:Class>
    


    <!-- https://augenauoc.github.io/CEMDHRO//CorrectiveAction -->


    <owl:Class rdf:about="https://augenauoc.github.io/CEMDHRO//CorrectiveAction">
        <rdfs:subClassOf rdf:resource="https://augenauoc.github.io/CEMDHRO/DescribedEntity"/>
        <rdfs:comment>Action taken to address a safety issue or incident involving a device.</rdfs:comment>
        <rdfs:label>CorrectiveAction</rdfs:label>
    </owl:Class>
    


    <!-- https://augenauoc.github.io/CEMDHRO//Critical -->


    <owl:Class rdf:about="https://augenauoc.github.io/CEMDHRO//Critical">
        <rdfs:subClassOf rdf:resource="https://augenauoc.github.io/CEMDHRO//Severity"/>
        <rdfs:label>Critical</rdfs:label>
    </owl:Class>
    


    <!-- https://augenauoc.github.io/CEMDHRO//CybersecurityRisk -->


    <owl:Class rdf:about="https://augenauoc.github.io/CEMDHRO//CybersecurityRisk">
        <rdfs:subClassOf rdf:resource="https://augenauoc.github.io/CEMDHRO//DeviceSafety"/>
        <rdfs:subClassOf rdf:resource="https://augenauoc.github.io/CEMDHRO//Risk"/>
        <rdfs:label>CybersecurityRisk</rdfs:label>
    </owl:Class>
    


    <!-- https://augenauoc.github.io/CEMDHRO//Device -->


    <owl:Class rdf:about="https://augenauoc.github.io/CEMDHRO//Device">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://augenauoc.github.io/CEMDHRO//hasRiskClass"/>
                <owl:someValuesFrom rdf:resource="https://augenauoc.github.io/CEMDHRO//RiskClass"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://augenauoc.github.io/CEMDHRO//regulatedUnder"/>
                <owl:someValuesFrom rdf:resource="https://augenauoc.github.io/CEMDHRO//RegulatoryFramework"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://augenauoc.github.io/CEMDHRO//hasManufacturer"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://augenauoc.github.io/CEMDHRO//Manufacturer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Class representing a medical device registered in the European medical device catalogue.</rdfs:comment>
        <rdfs:label>Device</rdfs:label>
    </owl:Class>
    


    <!-- https://augenauoc.github.io/CEMDHRO//DeviceFailure -->


    <owl:Class rdf:about="https://augenauoc.github.io/CEMDHRO//DeviceFailure">
        <rdfs:subClassOf rdf:resource="https://augenauoc.github.io/CEMDHRO//Risk"/>
        <rdfs:label>DeviceFailure</rdfs:label>
    </owl:Class>
    


    <!-- https://augenauoc.github.io/CEMDHRO//DevicePerformance -->


    <owl:Class rdf:about="https://augenauoc.github.io/CEMDHRO//DevicePerformance">
