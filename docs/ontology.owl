    <owl:Class rdf:about="https://augenauoc.github.io/CEMDHRO//NearMissIncident">
        <rdfs:subClassOf rdf:resource="https://augenauoc.github.io/CEMDHRO//Incident"/>
        <owl:disjointWith rdf:resource="https://augenauoc.github.io/CEMDHRO//SeriousIncident"/>
        <rdfs:label>NearMissIncident</rdfs:label>
