        <rdfs:label>PatientSex</rdfs:label>
    </owl:Class>
    


    <!-- https://augenauoc.github.io/CEMDHRO//PendingCorrectiveAction -->


    <owl:Class rdf:about="https://augenauoc.github.io/CEMDHRO//PendingCorrectiveAction">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://augenauoc.github.io/CEMDHRO//CorrectiveAction"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://augenauoc.github.io/CEMDHRO//hasStatus"/>
                        <owl:someValuesFrom rdf:resource="https://augenauoc.github.io/CEMDHRO//Open"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment>Comment: Corrective action inferred as pending because its status is open.</rdfs:comment>
        <rdfs:label>PendingCorrectiveAction</rdfs:label>
    </owl:Class>
    


    <!-- https://augenauoc.github.io/CEMDHRO//PriorityDevice -->


    <owl:Class rdf:about="https://augenauoc.github.io/CEMDHRO//PriorityDevice">
        <rdfs:comment>Comment: Device inferred as priority because it is involved in a critical incident.</rdfs:comment>
        <rdfs:label>PriorityDevice</rdfs:label>
    </owl:Class>
    


