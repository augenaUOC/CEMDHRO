###  https://augenauoc.github.io/CEMDHRO//Risk
<https://augenauoc.github.io/CEMDHRO//Risk> rdf:type owl:Class ;
                                            rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                              owl:onProperty <https://augenauoc.github.io/CEMDHRO//hasSeverity> ;
                                                              owl:allValuesFrom [ rdf:type owl:Class ;
                                                                                  owl:oneOf ( <https://augenauoc.github.io/CEMDHRO//Critical_instance>
                                                                                              <https://augenauoc.github.io/CEMDHRO//Moderate_instance>
                                                                                              <https://augenauoc.github.io/CEMDHRO//Serious_instance>
                                                                                            )
                                                                                ]
                                                            ] ,
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty <https://augenauoc.github.io/CEMDHRO//hasSeverity> ;
                                                              owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                              owl:onClass <https://augenauoc.github.io/CEMDHRO//Critical>
                                                            ] ;
                                            rdfs:comment "Potential hazard or adverse effect associated with a medical device." ;
                                            rdfs:label "Risk" .


