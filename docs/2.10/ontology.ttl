<https://augenauoc.github.io/CEMDHRO//DeviceUnit> rdf:type owl:Class ;
                                                  rdfs:subClassOf <https://augenauoc.github.io/CEMDHRO//AffectedUnit> ;
                                                  rdfs:label "DeviceUnit" .


