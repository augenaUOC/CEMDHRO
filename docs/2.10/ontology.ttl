###  https://augenauoc.github.io/CEMDHRO//hasScope
<https://augenauoc.github.io/CEMDHRO//hasScope> rdf:type owl:DatatypeProperty ;
                                                rdfs:domain <https://augenauoc.github.io/CEMDHRO//CorrectiveAction> ;
                                                rdfs:range xsd:string ;
                                                rdfs:comment "Scope of the corrective action" ;
                                                rdfs:label "hasScope" .


###  https://augenauoc.github.io/CEMDHRO//hasUDI
<https://augenauoc.github.io/CEMDHRO//hasUDI> rdf:type owl:DatatypeProperty ,
                                                       owl:FunctionalProperty ;
                                              rdfs:domain <https://augenauoc.github.io/CEMDHRO//Device> ;
                                              rdfs:range xsd:string ;
                                              rdfs:comment "Unique Device Identifier assigned to a medical device" ;
                                              rdfs:label "hasUDI" .


###  https://augenauoc.github.io/CEMDHRO//isActive
<https://augenauoc.github.io/CEMDHRO//isActive> rdf:type owl:DatatypeProperty ;
                                                rdfs:domain <https://augenauoc.github.io/CEMDHRO//Device> ;
                                                rdfs:range xsd:boolean ;
                                                rdfs:comment "Indicates whether the device is active" ;
                                                rdfs:label "isActive" .


