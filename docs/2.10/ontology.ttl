                                            rdfs:label "Open" .


###  https://augenauoc.github.io/CEMDHRO//OpenSafetyAlert
<https://augenauoc.github.io/CEMDHRO//OpenSafetyAlert> rdf:type owl:Class ;
                                                       rdfs:comment "Safety alert inferred as open when its status is Open." ;
                                                       rdfs:label "OpenSafetyAlert" .


###  https://augenauoc.github.io/CEMDHRO//PatientHarm
<https://augenauoc.github.io/CEMDHRO//PatientHarm> rdf:type owl:Class ;
                                                   rdfs:subClassOf <https://augenauoc.github.io/CEMDHRO//Risk> ;
                                                   rdfs:label "PatientHarm" .


###  https://augenauoc.github.io/CEMDHRO//PatientSex
<https://augenauoc.github.io/CEMDHRO//PatientSex> rdf:type owl:Class ;
                                                  rdfs:comment "Sex of the affected patient" ;
                                                  rdfs:label "PatientSex" .


###  https://augenauoc.github.io/CEMDHRO//PendingCorrectiveAction
<https://augenauoc.github.io/CEMDHRO//PendingCorrectiveAction> rdf:type owl:Class ;
                                                               owl:equivalentClass [ owl:intersectionOf ( <https://augenauoc.github.io/CEMDHRO//CorrectiveAction>
                                                                                                          [ rdf:type owl:Restriction ;
                                                                                                            owl:onProperty <https://augenauoc.github.io/CEMDHRO//hasStatus> ;
                                                                                                            owl:someValuesFrom <https://augenauoc.github.io/CEMDHRO//Open>
                                                                                                          ]
                                                                                                        ) ;
                                                                                     rdf:type owl:Class
                                                                                   ] ;
                                                               rdfs:comment "Comment: Corrective action inferred as pending because its status is open." ;
                                                               rdfs:label "PendingCorrectiveAction" .


###  https://augenauoc.github.io/CEMDHRO//PriorityDevice
<https://augenauoc.github.io/CEMDHRO//PriorityDevice> rdf:type owl:Class ;
                                                      rdfs:comment "Comment: Device inferred as priority because it is involved in a critical incident." ;
                                                      rdfs:label "PriorityDevice" .


###  https://augenauoc.github.io/CEMDHRO//Probability
<https://augenauoc.github.io/CEMDHRO//Probability> rdf:type owl:Class ;
                                                   rdfs:comment "Probability of having a risk" ;
                                                   rdfs:label "Probability" .


###  https://augenauoc.github.io/CEMDHRO//ProductQuality
<https://augenauoc.github.io/CEMDHRO//ProductQuality> rdf:type owl:Class ;
                                                      rdfs:subClassOf <https://augenauoc.github.io/CEMDHRO//Risk> ;
                                                      rdfs:label "ProductQuality" .


###  https://augenauoc.github.io/CEMDHRO//RadiationRisk
<https://augenauoc.github.io/CEMDHRO//RadiationRisk> rdf:type owl:Class ;
                                                     rdfs:subClassOf <https://augenauoc.github.io/CEMDHRO//PatientHarm> ,
                                                                     <https://augenauoc.github.io/CEMDHRO//Risk> ;
                                                     rdfs:label "RadiationRisk" .


###  https://augenauoc.github.io/CEMDHRO//Recall
<https://augenauoc.github.io/CEMDHRO//Recall> rdf:type owl:Class ;
