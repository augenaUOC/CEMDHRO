<https://augenauoc.github.io/CEMDHRO//DiagnosticRisk> rdf:type owl:Class ;
                                                      rdfs:subClassOf <https://augenauoc.github.io/CEMDHRO//DiagnosticError> ,
                                                                      <https://augenauoc.github.io/CEMDHRO//Risk> ;
                                                      rdfs:label "DiagnosticRisk" .


