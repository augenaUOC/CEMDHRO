@prefix : <https://augenauoc.github.io/CEMDHRO/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://augenauoc.github.io/CEMDHRO/> .

<https://augenauoc.github.io/CEMDHRO/> rdf:type owl:Ontology ;
                                        owl:versionIRI <https://augenauoc.github.io/CEMDHRO/> ;
                                        dc:title "CEMDHRO"
										dc:creator "AlfonsoUS"
										rdfs:comment "The CEMDHRO ontology has been developed to provide a structured and semantic representation of high-risk medical devices within the European regulatory context. It integrates key elements such as devices, manufacturers, risk classifications, incidents, and corrective actions, enabling consistent data modelling and interoperability. This ontology aims to support analysis, traceability, and decision-making processes in the domain of medical device safety and regulation." ;
                                        rdfs:label "CEMDHRO" ;
                                        owl:versionInfo 2.10 .

#################################################################
#    Annotation properties
#################################################################

###  http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled
<http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> rdf:type owl:AnnotationProperty .


###  https://augenauoc.github.io/CEMDHRO//hasIMDRFCode
<https://augenauoc.github.io/CEMDHRO//hasIMDRFCode> rdf:type owl:AnnotationProperty .


###  https://augenauoc.github.io/CEMDHRO//hasIncidentId
<https://augenauoc.github.io/CEMDHRO//hasIncidentId> rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  https://augenauoc.github.io/CEMDHRO/hasIMDRFCode
:hasIMDRFCode rdf:type owl:ObjectProperty ;
              owl:inverseOf :isIMDRFCodeOf ;
              rdfs:domain <https://augenauoc.github.io/CEMDHRO//Risk> ;
              rdfs:range <https://augenauoc.github.io/CEMDHRO//IMDRFCode> ;
              rdfs:label "hasIMDRFCode" .


###  https://augenauoc.github.io/CEMDHRO/isAddressedBy
:isAddressedBy rdf:type owl:ObjectProperty ;
               owl:inverseOf <https://augenauoc.github.io/CEMDHRO//addressesIncident> ;
               rdfs:domain <https://augenauoc.github.io/CEMDHRO//Incident> ;
               rdfs:range <https://augenauoc.github.io/CEMDHRO//CorrectiveAction> ;
               rdfs:label "isAddressedBy" .


###  https://augenauoc.github.io/CEMDHRO/isAffectedDeviceTypeOf
:isAffectedDeviceTypeOf rdf:type owl:ObjectProperty ;
                        owl:inverseOf <https://augenauoc.github.io/CEMDHRO//affectsDeviceType> ;
                        rdfs:domain <https://augenauoc.github.io/CEMDHRO//Device> ;
                        rdfs:range <https://augenauoc.github.io/CEMDHRO//Risk> ;
                        rdfs:label "isAffectedDeviceTypeOf" .


###  https://augenauoc.github.io/CEMDHRO/isAffectedRegionOf
:isAffectedRegionOf rdf:type owl:ObjectProperty ;
                    owl:inverseOf <https://augenauoc.github.io/CEMDHRO//affectsRegion> ;
                    rdfs:domain <https://augenauoc.github.io/CEMDHRO//Region> ;
                    rdfs:range <https://augenauoc.github.io/CEMDHRO//CorrectiveAction> ;
                    rdfs:label "isAffectedRegionOf" .


###  https://augenauoc.github.io/CEMDHRO/isAffectedUnitOf
:isAffectedUnitOf rdf:type owl:ObjectProperty ;
                  owl:inverseOf <https://augenauoc.github.io/CEMDHRO//hasAffectedUnit> ;
                  rdfs:domain <https://augenauoc.github.io/CEMDHRO//AffectedUnit> ;
                  rdfs:range <https://augenauoc.github.io/CEMDHRO//CorrectiveAction> ;
                  rdfs:label "isAffectedUnitOf" .


###  https://augenauoc.github.io/CEMDHRO/isIMDRFCodeOf
:isIMDRFCodeOf rdf:type owl:ObjectProperty ;
               rdfs:domain <https://augenauoc.github.io/CEMDHRO//IMDRFCode> ;
               rdfs:range <https://augenauoc.github.io/CEMDHRO//Risk> ;
               rdfs:label "isIMDRFCodeOf" .


###  https://augenauoc.github.io/CEMDHRO/isLocationOf
:isLocationOf rdf:type owl:ObjectProperty ;
              owl:inverseOf <https://augenauoc.github.io/CEMDHRO//locatedIn> ;
              rdfs:domain <https://augenauoc.github.io/CEMDHRO//Region> ;
              rdfs:range <https://augenauoc.github.io/CEMDHRO//Manufacturer> ;
              rdfs:label "isLocationOf" .


###  https://augenauoc.github.io/CEMDHRO/isPatientSexOf
:isPatientSexOf rdf:type owl:ObjectProperty ;
                owl:inverseOf <https://augenauoc.github.io/CEMDHRO//hasPatientSex> ;
                rdfs:domain <https://augenauoc.github.io/CEMDHRO//PatientSex> ;
                rdfs:range <https://augenauoc.github.io/CEMDHRO//Incident> ;
                rdfs:label "isPatientSexOf" .


###  https://augenauoc.github.io/CEMDHRO/isProbabilityOf
:isProbabilityOf rdf:type owl:ObjectProperty ;
                 owl:inverseOf <https://augenauoc.github.io/CEMDHRO//hasProbability> ;
                 rdfs:domain <https://augenauoc.github.io/CEMDHRO//Probability> ;
                 rdfs:range <https://augenauoc.github.io/CEMDHRO//Risk> ;
                 rdfs:label "isProbabilityOf" .


###  https://augenauoc.github.io/CEMDHRO/isReportLocationOf
:isReportLocationOf rdf:type owl:ObjectProperty ;
                    owl:inverseOf <https://augenauoc.github.io/CEMDHRO//reportedIn> ;
                    rdfs:domain <https://augenauoc.github.io/CEMDHRO//Region> ;
                    rdfs:range <https://augenauoc.github.io/CEMDHRO//Incident> ;
                    rdfs:label "isReportLocationOf" .


###  https://augenauoc.github.io/CEMDHRO/isRiskClassOf
:isRiskClassOf rdf:type owl:ObjectProperty ;
               owl:inverseOf <https://augenauoc.github.io/CEMDHRO//hasRiskClass> ;
               rdfs:domain <https://augenauoc.github.io/CEMDHRO//RiskClass> ;
               rdfs:range <https://augenauoc.github.io/CEMDHRO//Device> ;
               rdfs:label "isRiskClassOf" .


###  https://augenauoc.github.io/CEMDHRO/isRiskOf
:isRiskOf rdf:type owl:ObjectProperty ;
          owl:inverseOf <https://augenauoc.github.io/CEMDHRO//hasRisk> ;
          rdfs:domain <https://augenauoc.github.io/CEMDHRO//Risk> ;
          rdfs:range <https://augenauoc.github.io/CEMDHRO//Incident> ;
          rdfs:label "isRiskOf" .


###  https://augenauoc.github.io/CEMDHRO/isSeverityOf
:isSeverityOf rdf:type owl:ObjectProperty ;
              owl:inverseOf <https://augenauoc.github.io/CEMDHRO//hasSeverity> ;
              rdfs:domain <https://augenauoc.github.io/CEMDHRO//Severity> ;
              rdfs:range <https://augenauoc.github.io/CEMDHRO//Risk> ;
              rdfs:label "isSeverityOf" .


###  https://augenauoc.github.io/CEMDHRO/isStatusOf
:isStatusOf rdf:type owl:ObjectProperty ;
            owl:inverseOf <https://augenauoc.github.io/CEMDHRO//hasStatus> ;
            rdfs:domain <https://augenauoc.github.io/CEMDHRO//Status> ;
            rdfs:range <https://augenauoc.github.io/CEMDHRO//CorrectiveAction> ;
            rdfs:label "isStatusOf" .


###  https://augenauoc.github.io/CEMDHRO/regulatesDevice
:regulatesDevice rdf:type owl:ObjectProperty ;
                 owl:inverseOf <https://augenauoc.github.io/CEMDHRO//regulatedUnder> ;
                 rdfs:domain <https://augenauoc.github.io/CEMDHRO//RegulatoryFramework> ;
                 rdfs:range <https://augenauoc.github.io/CEMDHRO//Device> ;
                 rdfs:label "regulatesDevice" .


###  https://augenauoc.github.io/CEMDHRO/reportsIncident
:reportsIncident rdf:type owl:ObjectProperty ;
                 rdfs:domain <https://augenauoc.github.io/CEMDHRO//Manufacturer> ;
                 rdfs:range <https://augenauoc.github.io/CEMDHRO//Incident> ;
                 rdfs:label "reportsIncident" .


###  https://augenauoc.github.io/CEMDHRO//addressesIncident
<https://augenauoc.github.io/CEMDHRO//addressesIncident> rdf:type owl:ObjectProperty ;
                                                         rdfs:domain <https://augenauoc.github.io/CEMDHRO//CorrectiveAction> ;
                                                         rdfs:range <https://augenauoc.github.io/CEMDHRO//Incident> ;
                                                         rdfs:comment "Relates a corrective action to the incident it addresses" ;
                                                         rdfs:label "addressesIncident" .


###  https://augenauoc.github.io/CEMDHRO//affectsDevice
<https://augenauoc.github.io/CEMDHRO//affectsDevice> rdf:type owl:ObjectProperty ;
                                                     owl:inverseOf <https://augenauoc.github.io/CEMDHRO//isAffectedBy> ;
                                                     rdfs:domain <https://augenauoc.github.io/CEMDHRO//Incident> ;
                                                     rdfs:range <https://augenauoc.github.io/CEMDHRO//Device> ;
                                                     rdfs:comment "Relates an incident to the affected medical device" ;
                                                     rdfs:label "affectsDevice" .


###  https://augenauoc.github.io/CEMDHRO//affectsDeviceType
<https://augenauoc.github.io/CEMDHRO//affectsDeviceType> rdf:type owl:ObjectProperty ;
                                                         rdfs:domain <https://augenauoc.github.io/CEMDHRO//Risk> ;
                                                         rdfs:range <https://augenauoc.github.io/CEMDHRO//Device> ;
                                                         rdfs:label "affectsDeviceType" .


###  https://augenauoc.github.io/CEMDHRO//affectsRegion
<https://augenauoc.github.io/CEMDHRO//affectsRegion> rdf:type owl:ObjectProperty ;
                                                     rdfs:domain <https://augenauoc.github.io/CEMDHRO//CorrectiveAction> ;
                                                     rdfs:range <https://augenauoc.github.io/CEMDHRO//Region> ;
                                                     rdfs:comment "Relates a corrective action to the affected geographical region" ;
                                                     rdfs:label "affectsRegion" .


###  https://augenauoc.github.io/CEMDHRO//hasAffectedUnit
<https://augenauoc.github.io/CEMDHRO//hasAffectedUnit> rdf:type owl:ObjectProperty ;
                                                       rdfs:domain <https://augenauoc.github.io/CEMDHRO//CorrectiveAction> ;
                                                       rdfs:range <https://augenauoc.github.io/CEMDHRO//AffectedUnit> ;
                                                       rdfs:comment "Indicates the unit used for the affected quantity" ;
                                                       rdfs:label "hasAffectedUnit" .


###  https://augenauoc.github.io/CEMDHRO//hasManufacturer
<https://augenauoc.github.io/CEMDHRO//hasManufacturer> rdf:type owl:ObjectProperty ;
                                                       owl:inverseOf <https://augenauoc.github.io/CEMDHRO//manufactures> ;
                                                       rdfs:domain <https://augenauoc.github.io/CEMDHRO//Device> ;
                                                       rdfs:range <https://augenauoc.github.io/CEMDHRO//Manufacturer> ;
                                                       rdfs:comment "Relates a medical device to its manufacturer" ;
                                                       rdfs:label "hasManufacturer" .


###  https://augenauoc.github.io/CEMDHRO//hasPatientSex
<https://augenauoc.github.io/CEMDHRO//hasPatientSex> rdf:type owl:ObjectProperty ;
                                                     rdfs:domain <https://augenauoc.github.io/CEMDHRO//Incident> ;
                                                     rdfs:range <https://augenauoc.github.io/CEMDHRO//PatientSex> ;
                                                     rdfs:label "hasPatientSex" .


###  https://augenauoc.github.io/CEMDHRO//hasProbability
<https://augenauoc.github.io/CEMDHRO//hasProbability> rdf:type owl:ObjectProperty ;
                                                      rdfs:domain <https://augenauoc.github.io/CEMDHRO//Risk> ;
                                                      rdfs:range <https://augenauoc.github.io/CEMDHRO//Probability> ;
                                                      rdfs:comment "Relates a risk to its probability level" ;
                                                      rdfs:label "hasProbability" .


###  https://augenauoc.github.io/CEMDHRO//hasRisk
<https://augenauoc.github.io/CEMDHRO//hasRisk> rdf:type owl:ObjectProperty ;
                                               rdfs:domain <https://augenauoc.github.io/CEMDHRO//Incident> ;
                                               rdfs:range <https://augenauoc.github.io/CEMDHRO//Risk> ;
                                               rdfs:comment "Relates a device or incident to an associated risk" ;
                                               rdfs:label "hasRisk" .


###  https://augenauoc.github.io/CEMDHRO//hasRiskClass
<https://augenauoc.github.io/CEMDHRO//hasRiskClass> rdf:type owl:ObjectProperty ;
                                                    rdfs:domain <https://augenauoc.github.io/CEMDHRO//Device> ;
                                                    rdfs:range <https://augenauoc.github.io/CEMDHRO//RiskClass> ;
                                                    rdfs:comment "Relates a device to its regulatory risk class" ;
                                                    rdfs:label "hasRiskClass" .


###  https://augenauoc.github.io/CEMDHRO//hasSeverity
<https://augenauoc.github.io/CEMDHRO//hasSeverity> rdf:type owl:ObjectProperty ;
                                                   rdfs:domain <https://augenauoc.github.io/CEMDHRO//Risk> ;
                                                   rdfs:range <https://augenauoc.github.io/CEMDHRO//Severity> ;
                                                   rdfs:comment "Relates a risk to its severity level" ;
                                                   rdfs:label "hasSeverity" .


###  https://augenauoc.github.io/CEMDHRO//hasStatus
<https://augenauoc.github.io/CEMDHRO//hasStatus> rdf:type owl:ObjectProperty ;
                                                 rdfs:domain <https://augenauoc.github.io/CEMDHRO//CorrectiveAction> ;
                                                 rdfs:range <https://augenauoc.github.io/CEMDHRO//Status> ;
                                                 rdfs:comment "Relates a corrective action to its current status" ;
                                                 rdfs:label "hasStatus" .


###  https://augenauoc.github.io/CEMDHRO//isAffectedBy
<https://augenauoc.github.io/CEMDHRO//isAffectedBy> rdf:type owl:ObjectProperty ;
                                                    rdfs:domain <https://augenauoc.github.io/CEMDHRO//Device> ;
                                                    rdfs:range <https://augenauoc.github.io/CEMDHRO//Incident> ;
                                                    rdfs:label "isAffectedBy" .


###  https://augenauoc.github.io/CEMDHRO//locatedIn
<https://augenauoc.github.io/CEMDHRO//locatedIn> rdf:type owl:ObjectProperty ;
                                                 rdfs:domain <https://augenauoc.github.io/CEMDHRO//Manufacturer> ;
                                                 rdfs:range <https://augenauoc.github.io/CEMDHRO//Region> ;
                                                 rdfs:comment "Relates a manufacturer to its geographical region" ;
                                                 rdfs:label "locatedIn" .


###  https://augenauoc.github.io/CEMDHRO//manufactures
<https://augenauoc.github.io/CEMDHRO//manufactures> rdf:type owl:ObjectProperty ;
                                                    rdfs:domain <https://augenauoc.github.io/CEMDHRO//Manufacturer> ;
                                                    rdfs:range <https://augenauoc.github.io/CEMDHRO//Device> ;
                                                    rdfs:comment "Relates a manufacturer to the devices it produces" ;
                                                    rdfs:label "manufactures" .


###  https://augenauoc.github.io/CEMDHRO//regulatedUnder
<https://augenauoc.github.io/CEMDHRO//regulatedUnder> rdf:type owl:ObjectProperty ;
                                                      rdfs:domain <https://augenauoc.github.io/CEMDHRO//Device> ;
                                                      rdfs:range <https://augenauoc.github.io/CEMDHRO//RegulatoryFramework> ;
                                                      rdfs:comment "Relates a device to the applicable regulatory framework" ;
                                                      rdfs:label "regulatedUnder" .


###  https://augenauoc.github.io/CEMDHRO//reportedBy
<https://augenauoc.github.io/CEMDHRO//reportedBy> rdf:type owl:ObjectProperty ;
                                                  rdfs:domain <https://augenauoc.github.io/CEMDHRO//Incident> ;
                                                  rdfs:range <https://augenauoc.github.io/CEMDHRO//Manufacturer> ;
                                                  rdfs:comment "Relates an incident to the manufacturer that reported it" ;
                                                  rdfs:label "reportedBy" .


###  https://augenauoc.github.io/CEMDHRO//reportedIn
<https://augenauoc.github.io/CEMDHRO//reportedIn> rdf:type owl:ObjectProperty ;
                                                  rdfs:domain <https://augenauoc.github.io/CEMDHRO//Incident> ;
                                                  rdfs:range <https://augenauoc.github.io/CEMDHRO//Region> ;
                                                  rdfs:comment "Relates an incident to the region where it was reported" ;
                                                  rdfs:label "reportedIn" .


#################################################################
#    Data properties
#################################################################

###  https://augenauoc.github.io/CEMDHRO//hasActionDate
<https://augenauoc.github.io/CEMDHRO//hasActionDate> rdf:type owl:DatatypeProperty ;
                                                     rdfs:domain <https://augenauoc.github.io/CEMDHRO//CorrectiveAction> ;
                                                     rdfs:range xsd:date ;
                                                     rdfs:comment "Date when the corrective action was initiated" ;
                                                     rdfs:label "hasActionDate" .


###  https://augenauoc.github.io/CEMDHRO//hasAffectedQuantity
<https://augenauoc.github.io/CEMDHRO//hasAffectedQuantity> rdf:type owl:DatatypeProperty ;
                                                           rdfs:domain <https://augenauoc.github.io/CEMDHRO//CorrectiveAction> ;
                                                           rdfs:range xsd:integer ;
                                                           rdfs:comment "Number of affected devices or tests" ;
                                                           rdfs:label "hasAffectedQuantity" .


###  https://augenauoc.github.io/CEMDHRO//hasAuthorizationNumber
<https://augenauoc.github.io/CEMDHRO//hasAuthorizationNumber> rdf:type owl:DatatypeProperty ;
                                                              rdfs:domain <https://augenauoc.github.io/CEMDHRO//Manufacturer> ;
                                                              rdfs:range xsd:string ;
                                                              rdfs:comment "Authorization number assigned to a manufacturer" ;
                                                              rdfs:label "hasAuthorizationNumber" .


###  https://augenauoc.github.io/CEMDHRO//hasClosureDate
<https://augenauoc.github.io/CEMDHRO//hasClosureDate> rdf:type owl:DatatypeProperty ;
                                                      rdfs:domain <https://augenauoc.github.io/CEMDHRO//CorrectiveAction> ;
                                                      rdfs:range xsd:date ;
                                                      rdfs:comment "Date when the corrective action was closed" ;
                                                      rdfs:label "hasClosureDate" .


###  https://augenauoc.github.io/CEMDHRO//hasCompetentAuthority
<https://augenauoc.github.io/CEMDHRO//hasCompetentAuthority> rdf:type owl:DatatypeProperty ;
                                                             rdfs:domain <https://augenauoc.github.io/CEMDHRO//Manufacturer> ;
                                                             rdfs:range xsd:string ;
                                                             rdfs:comment "Competent authority responsible for the manufacturer" ;
                                                             rdfs:label "hasCompetentAuthority" .


###  https://augenauoc.github.io/CEMDHRO//hasCorrectiveActionTaken
<https://augenauoc.github.io/CEMDHRO//hasCorrectiveActionTaken> rdf:type owl:DatatypeProperty ;
                                                                rdfs:domain <https://augenauoc.github.io/CEMDHRO//Incident> ;
                                                                rdfs:range xsd:boolean ;
                                                                rdfs:comment "Indicates whether a corrective action was taken for the incident" ;
                                                                rdfs:label "hasCorrectiveActionTaken" .


###  https://augenauoc.github.io/CEMDHRO//hasDescription
<https://augenauoc.github.io/CEMDHRO//hasDescription> rdf:type owl:DatatypeProperty ;
                                                      rdfs:domain :DescribedEntity ;
                                                      rdfs:range xsd:string ;
                                                      rdfs:comment "Textual description of an entity" ;
                                                      rdfs:label "hasDescription" .


###  https://augenauoc.github.io/CEMDHRO//hasDetectionDate
<https://augenauoc.github.io/CEMDHRO//hasDetectionDate> rdf:type owl:DatatypeProperty ;
                                                        rdfs:domain <https://augenauoc.github.io/CEMDHRO//Incident> ;
                                                        rdfs:range xsd:date ;
                                                        rdfs:comment "Date when the incident was detected" ;
                                                        rdfs:label "hasDetectionDate" .


###  https://augenauoc.github.io/CEMDHRO//hasDeviceId
<https://augenauoc.github.io/CEMDHRO//hasDeviceId> rdf:type owl:DatatypeProperty ,
                                                            owl:FunctionalProperty ;
                                                   rdfs:domain <https://augenauoc.github.io/CEMDHRO//Device> ;
                                                   rdfs:range xsd:string ;
                                                   rdfs:label "hasDeviceId" .


###  https://augenauoc.github.io/CEMDHRO//hasDeviceName
<https://augenauoc.github.io/CEMDHRO//hasDeviceName> rdf:type owl:DatatypeProperty ;
                                                     rdfs:domain <https://augenauoc.github.io/CEMDHRO//Device> ;
                                                     rdfs:range xsd:string ;
                                                     rdfs:comment "Name of the medical device" ;
                                                     rdfs:label "hasDeviceName" .


###  https://augenauoc.github.io/CEMDHRO//hasEmail
<https://augenauoc.github.io/CEMDHRO//hasEmail> rdf:type owl:DatatypeProperty ;
                                                rdfs:domain <https://augenauoc.github.io/CEMDHRO//Manufacturer> ;
                                                rdfs:range xsd:string ;
                                                rdfs:comment "Contact email of the manufacturer" ;
                                                rdfs:label "hasEmail" .


###  https://augenauoc.github.io/CEMDHRO//hasEudamedIncRef
<https://augenauoc.github.io/CEMDHRO//hasEudamedIncRef> rdf:type owl:DatatypeProperty ;
                                                        rdfs:domain <https://augenauoc.github.io/CEMDHRO//Incident> ;
                                                        rdfs:range xsd:string ;
                                                        rdfs:comment "EUDAMED reference identifier for the incident" ;
                                                        rdfs:label "hasEudamedIncRef" .


###  https://augenauoc.github.io/CEMDHRO//hasEventDate
<https://augenauoc.github.io/CEMDHRO//hasEventDate> rdf:type owl:DatatypeProperty ;
                                                    rdfs:domain <https://augenauoc.github.io/CEMDHRO//Incident> ;
                                                    rdfs:range xsd:date ;
                                                    rdfs:comment "Date when the incident occurred" ;
                                                    rdfs:label "hasEventDate" .


###  https://augenauoc.github.io/CEMDHRO//hasFSCA
<https://augenauoc.github.io/CEMDHRO//hasFSCA> rdf:type owl:DatatypeProperty ,
                                                        owl:FunctionalProperty ;
                                               rdfs:domain <https://augenauoc.github.io/CEMDHRO//CorrectiveAction> ;
                                               rdfs:range xsd:string ;
                                               rdfs:comment "EUDAMED FSCA reference identifier" ;
                                               rdfs:label "hasFSCA" .


###  https://augenauoc.github.io/CEMDHRO//hasManufacturerId
<https://augenauoc.github.io/CEMDHRO//hasManufacturerId> rdf:type owl:DatatypeProperty ;
                                                         rdfs:domain <https://augenauoc.github.io/CEMDHRO//Manufacturer> ;
                                                         rdfs:range xsd:string ;
                                                         rdfs:label "hasManufacturerId" .


###  https://augenauoc.github.io/CEMDHRO//hasManufacturerName
<https://augenauoc.github.io/CEMDHRO//hasManufacturerName> rdf:type owl:DatatypeProperty ;
                                                           rdfs:domain <https://augenauoc.github.io/CEMDHRO//Manufacturer> ;
                                                           rdfs:range xsd:string ;
                                                           rdfs:comment "Name of the manufacturer" ;
                                                           rdfs:label "hasManufacturerName" .


###  https://augenauoc.github.io/CEMDHRO//hasOutcome
<https://augenauoc.github.io/CEMDHRO//hasOutcome> rdf:type owl:DatatypeProperty ;
                                                  rdfs:domain <https://augenauoc.github.io/CEMDHRO//Incident> ;
                                                  rdfs:range xsd:string ;
                                                  rdfs:comment "Textual description of the incident outcome" ;
                                                  rdfs:label "hasOutcome" .


###  https://augenauoc.github.io/CEMDHRO//hasPatientAge
<https://augenauoc.github.io/CEMDHRO//hasPatientAge> rdf:type owl:DatatypeProperty ;
                                                     rdfs:domain <https://augenauoc.github.io/CEMDHRO//Incident> ;
                                                     rdfs:range xsd:integer ;
                                                     rdfs:comment "Age of the patient involved in the incident" ;
                                                     rdfs:label "hasPatientAge" .


