<https://augenauoc.github.io/CEMDHRO//ClassA> rdf:type owl:Class ;
                                              rdfs:subClassOf <https://augenauoc.github.io/CEMDHRO//IVDRRiskClass> ;
                                              rdfs:label "ClassA" .


###  https://augenauoc.github.io/CEMDHRO//ClassB
<https://augenauoc.github.io/CEMDHRO//ClassB> rdf:type owl:Class ;
                                              rdfs:subClassOf <https://augenauoc.github.io/CEMDHRO//IVDRRiskClass> ;
                                              rdfs:label "ClassB" .


###  https://augenauoc.github.io/CEMDHRO//ClassC
<https://augenauoc.github.io/CEMDHRO//ClassC> rdf:type owl:Class ;
                                              rdfs:subClassOf <https://augenauoc.github.io/CEMDHRO//IVDRRiskClass> ;
                                              rdfs:label "ClassC" .


###  https://augenauoc.github.io/CEMDHRO//ClassD
<https://augenauoc.github.io/CEMDHRO//ClassD> rdf:type owl:Class ;
                                              rdfs:subClassOf <https://augenauoc.github.io/CEMDHRO//IVDRRiskClass> ;
                                              rdfs:label "ClassD" .


###  https://augenauoc.github.io/CEMDHRO//ClassI
<https://augenauoc.github.io/CEMDHRO//ClassI> rdf:type owl:Class ;
                                              rdfs:subClassOf <https://augenauoc.github.io/CEMDHRO//MDRRiskClass> ;
                                              rdfs:label "ClassI" .


###  https://augenauoc.github.io/CEMDHRO//ClassIII
<https://augenauoc.github.io/CEMDHRO//ClassIII> rdf:type owl:Class ;
                                                rdfs:subClassOf <https://augenauoc.github.io/CEMDHRO//MDRRiskClass> ;
                                                rdfs:comment "Highest risk category." ;
                                                rdfs:label "ClassIII" .


###  https://augenauoc.github.io/CEMDHRO//ClassIIa
<https://augenauoc.github.io/CEMDHRO//ClassIIa> rdf:type owl:Class ;
                                                rdfs:subClassOf <https://augenauoc.github.io/CEMDHRO//MDRRiskClass> ;
                                                rdfs:label "ClassIIa" .


###  https://augenauoc.github.io/CEMDHRO//ClassIIb
<https://augenauoc.github.io/CEMDHRO//ClassIIb> rdf:type owl:Class ;
                                                rdfs:subClassOf <https://augenauoc.github.io/CEMDHRO//MDRRiskClass> ;
                                                rdfs:label "ClassIIb" .


###  https://augenauoc.github.io/CEMDHRO//Closed
<https://augenauoc.github.io/CEMDHRO//Closed> rdf:type owl:Class ;
                                              rdfs:subClassOf <https://augenauoc.github.io/CEMDHRO//Status> ;
                                              owl:disjointWith <https://augenauoc.github.io/CEMDHRO//Open> ;
                                              rdfs:label "Closed" .


###  https://augenauoc.github.io/CEMDHRO//ClosedRecall
<https://augenauoc.github.io/CEMDHRO//ClosedRecall> rdf:type owl:Class ;
                                                    rdfs:comment "Recall inferred as closed when its status is Closed." ;
                                                    rdfs:label "ClosedRecall" .


###  https://augenauoc.github.io/CEMDHRO//ContaminationRisk
<https://augenauoc.github.io/CEMDHRO//ContaminationRisk> rdf:type owl:Class ;
                                                         rdfs:subClassOf <https://augenauoc.github.io/CEMDHRO//ProductQuality> ,
                                                                         <https://augenauoc.github.io/CEMDHRO//Risk> ;
                                                         rdfs:label "ContaminationRisk" .


###  https://augenauoc.github.io/CEMDHRO//CorrectiveAction
<https://augenauoc.github.io/CEMDHRO//CorrectiveAction> rdf:type owl:Class ;
                                                        rdfs:subClassOf :DescribedEntity ;
                                                        rdfs:comment "Action taken to address a safety issue or incident involving a device." ;
                                                        rdfs:label "CorrectiveAction" .


###  https://augenauoc.github.io/CEMDHRO//Critical
<https://augenauoc.github.io/CEMDHRO//Critical> rdf:type owl:Class ;
                                                rdfs:subClassOf <https://augenauoc.github.io/CEMDHRO//Severity> ;
                                                rdfs:label "Critical" .


###  https://augenauoc.github.io/CEMDHRO//CybersecurityRisk
<https://augenauoc.github.io/CEMDHRO//CybersecurityRisk> rdf:type owl:Class ;
                                                         rdfs:subClassOf <https://augenauoc.github.io/CEMDHRO//DeviceSafety> ,
                                                                         <https://augenauoc.github.io/CEMDHRO//Risk> ;
                                                         rdfs:label "CybersecurityRisk" .


###  https://augenauoc.github.io/CEMDHRO//Device
<https://augenauoc.github.io/CEMDHRO//Device> rdf:type owl:Class ;
                                              rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                                owl:onProperty <https://augenauoc.github.io/CEMDHRO//hasRiskClass> ;
                                                                owl:someValuesFrom <https://augenauoc.github.io/CEMDHRO//RiskClass>
                                                              ] ,
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty <https://augenauoc.github.io/CEMDHRO//regulatedUnder> ;
                                                                owl:someValuesFrom <https://augenauoc.github.io/CEMDHRO//RegulatoryFramework>
                                                              ] ,
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty <https://augenauoc.github.io/CEMDHRO//hasManufacturer> ;
                                                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                owl:onClass <https://augenauoc.github.io/CEMDHRO//Manufacturer>
                                                              ] ;
                                              rdfs:comment "Class representing a medical device registered in the European medical device catalogue." ;
                                              rdfs:label "Device" .


###  https://augenauoc.github.io/CEMDHRO//DeviceFailure
<https://augenauoc.github.io/CEMDHRO//DeviceFailure> rdf:type owl:Class ;
                                                     rdfs:subClassOf <https://augenauoc.github.io/CEMDHRO//Risk> ;
                                                     rdfs:label "DeviceFailure" .


###  https://augenauoc.github.io/CEMDHRO//DevicePerformance
<https://augenauoc.github.io/CEMDHRO//DevicePerformance> rdf:type owl:Class ;
                                                         rdfs:subClassOf <https://augenauoc.github.io/CEMDHRO//Risk> ;
                                                         rdfs:label "DevicePerformance" .


