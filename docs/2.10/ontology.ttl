<https://augenauoc.github.io/CEMDHRO//NearMissIncident> rdf:type owl:Class ;
                                                        rdfs:subClassOf <https://augenauoc.github.io/CEMDHRO//Incident> ;
                                                        owl:disjointWith <https://augenauoc.github.io/CEMDHRO//SeriousIncident> ;
                                                        rdfs:label "NearMissIncident" .


