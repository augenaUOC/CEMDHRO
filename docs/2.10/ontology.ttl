<https://augenauoc.github.io/CEMDHRO//DeviceSafety> rdf:type owl:Class ;
                                                    rdfs:subClassOf <https://augenauoc.github.io/CEMDHRO//Risk> ;
                                                    rdfs:label "DeviceSafety" .


