                                                   rdfs:domain <https://augenauoc.github.io/CEMDHRO//Risk> ;
                                                   rdfs:range xsd:string ;
                                                   rdfs:comment "Name of the identified risk" ;
                                                   rdfs:label "hasRiskName" .


###  https://augenauoc.github.io/CEMDHRO//hasSRN
<https://augenauoc.github.io/CEMDHRO//hasSRN> rdf:type owl:DatatypeProperty ,
                                                       owl:FunctionalProperty ;
                                              rdfs:domain <https://augenauoc.github.io/CEMDHRO//Manufacturer> ;
