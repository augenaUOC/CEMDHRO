<https://augenauoc.github.io/CEMDHRO//ImplantableDevice> rdf:type owl:Class ;
                                                         rdfs:subClassOf <https://augenauoc.github.io/CEMDHRO//Device> .


###  https://augenauoc.github.io/CEMDHRO//InSituCorrection
<https://augenauoc.github.io/CEMDHRO//InSituCorrection> rdf:type owl:Class ;
                                                        rdfs:subClassOf <https://augenauoc.github.io/CEMDHRO//CorrectiveAction> ;
                                                        rdfs:label "InSituCorrection" .


###  https://augenauoc.github.io/CEMDHRO//InVitroDiagnosticDevice
<https://augenauoc.github.io/CEMDHRO//InVitroDiagnosticDevice> rdf:type owl:Class ;
                                                               rdfs:subClassOf <https://augenauoc.github.io/CEMDHRO//Device> .


###  https://augenauoc.github.io/CEMDHRO//Incident
<https://augenauoc.github.io/CEMDHRO//Incident> rdf:type owl:Class ;
                                                rdfs:subClassOf :DescribedEntity ,
                                                                [ rdf:type owl:Restriction ;
                                                                  owl:onProperty <https://augenauoc.github.io/CEMDHRO//affectsDevice> ;
                                                                  owl:someValuesFrom <https://augenauoc.github.io/CEMDHRO//Device>
                                                                ] ;
                                                rdfs:comment "Event related to the use of a medical device that may impact patient safety." ;
                                                rdfs:label "Incident" .


###  https://augenauoc.github.io/CEMDHRO//InfectionRisk
<https://augenauoc.github.io/CEMDHRO//InfectionRisk> rdf:type owl:Class ;
                                                     rdfs:subClassOf <https://augenauoc.github.io/CEMDHRO//PatientHarm> ,
                                                                     <https://augenauoc.github.io/CEMDHRO//Risk> ;
                                                     rdfs:label "InfectionRisk" .


###  https://augenauoc.github.io/CEMDHRO//InjuryRisk
<https://augenauoc.github.io/CEMDHRO//InjuryRisk> rdf:type owl:Class ;
                                                  rdfs:subClassOf <https://augenauoc.github.io/CEMDHRO//PatientHarm> ,
                                                                  <https://augenauoc.github.io/CEMDHRO//Risk> ;
                                                  rdfs:label "InjuryRisk" .


###  https://augenauoc.github.io/CEMDHRO//InterferenceRisk
<https://augenauoc.github.io/CEMDHRO//InterferenceRisk> rdf:type owl:Class ;
                                                        rdfs:subClassOf <https://augenauoc.github.io/CEMDHRO//DevicePerformance> ,
                                                                        <https://augenauoc.github.io/CEMDHRO//Risk> ;
                                                        rdfs:label "InterferenceRisk" .


###  https://augenauoc.github.io/CEMDHRO//Low
<https://augenauoc.github.io/CEMDHRO//Low> rdf:type owl:Class ;
                                           rdfs:subClassOf <https://augenauoc.github.io/CEMDHRO//Probability> ;
                                           rdfs:label "Low" .


###  https://augenauoc.github.io/CEMDHRO//MDR
<https://augenauoc.github.io/CEMDHRO//MDR> rdf:type owl:Class ;
                                           rdfs:subClassOf <https://augenauoc.github.io/CEMDHRO//RegulatoryFramework> ;
                                           rdfs:comment "Medical Device Regulation" ;
                                           rdfs:label "MDR" .


###  https://augenauoc.github.io/CEMDHRO//MDRRiskClass
<https://augenauoc.github.io/CEMDHRO//MDRRiskClass> rdf:type owl:Class ;
                                                    rdfs:subClassOf <https://augenauoc.github.io/CEMDHRO//RiskClass> ;
                                                    rdfs:label "MDRRiskClass" .


###  https://augenauoc.github.io/CEMDHRO//MalfunctionRisk
<https://augenauoc.github.io/CEMDHRO//MalfunctionRisk> rdf:type owl:Class ;
                                                       rdfs:subClassOf <https://augenauoc.github.io/CEMDHRO//DeviceFailure> ,
                                                                       <https://augenauoc.github.io/CEMDHRO//DevicePerformance> ,
                                                                       <https://augenauoc.github.io/CEMDHRO//Risk> ;
                                                       rdfs:label "MalfunctionRisk" .


###  https://augenauoc.github.io/CEMDHRO//Manufacturer
<https://augenauoc.github.io/CEMDHRO//Manufacturer> rdf:type owl:Class ;
                                                    rdfs:comment "Organization responsible for producing medical devices." ;
                                                    rdfs:label "Manufacturer" .


###  https://augenauoc.github.io/CEMDHRO//MaterialRisk
<https://augenauoc.github.io/CEMDHRO//MaterialRisk> rdf:type owl:Class ;
                                                    rdfs:subClassOf <https://augenauoc.github.io/CEMDHRO//PatientHarm> ,
                                                                    <https://augenauoc.github.io/CEMDHRO//Risk> ;
                                                    rdfs:label "MaterialRisk" .


###  https://augenauoc.github.io/CEMDHRO//Medium
<https://augenauoc.github.io/CEMDHRO//Medium> rdf:type owl:Class ;
                                              rdfs:subClassOf <https://augenauoc.github.io/CEMDHRO//Probability> ;
                                              rdfs:label "Medium" .


###  https://augenauoc.github.io/CEMDHRO//Moderate
<https://augenauoc.github.io/CEMDHRO//Moderate> rdf:type owl:Class ;
                                                rdfs:subClassOf <https://augenauoc.github.io/CEMDHRO//Severity> ;
                                                rdfs:label "Moderate" .


