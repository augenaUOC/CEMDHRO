#################################################################
#    Classes
#################################################################

###  https://augenauoc.github.io/CEMDHRO/DescribedEntity
:DescribedEntity rdf:type owl:Class ;
                 rdfs:label "DescribedEntity" .


###  https://augenauoc.github.io/CEMDHRO//ActiveDevice
<https://augenauoc.github.io/CEMDHRO//ActiveDevice> rdf:type owl:Class ;
                                                    rdfs:subClassOf <https://augenauoc.github.io/CEMDHRO//Device> .


###  https://augenauoc.github.io/CEMDHRO//ActiveImplant
<https://augenauoc.github.io/CEMDHRO//ActiveImplant> rdf:type owl:Class ;
                                                     rdfs:subClassOf <https://augenauoc.github.io/CEMDHRO//Device> .


###  https://augenauoc.github.io/CEMDHRO//AffectedUnit
<https://augenauoc.github.io/CEMDHRO//AffectedUnit> rdf:type owl:Class ;
                                                    rdfs:comment "Number of affected units" ;
                                                    rdfs:label "AffectedUnit" .


