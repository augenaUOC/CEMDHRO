[ rdf:type owl:AllDisjointClasses ;
  owl:members ( <https://augenauoc.github.io/CEMDHRO//Critical>
                <https://augenauoc.github.io/CEMDHRO//Moderate>
                <https://augenauoc.github.io/CEMDHRO//Serious>
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( <https://augenauoc.github.io/CEMDHRO//High>
                <https://augenauoc.github.io/CEMDHRO//Low>
                <https://augenauoc.github.io/CEMDHRO//Medium>
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( <https://augenauoc.github.io/CEMDHRO//InSituCorrection>
